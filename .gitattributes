* text=auto

# THIRD_PARTY_NOTICES.md is generated by scripts/local/gen-third-party-notices.ps1,
# which always emits LF. Force LF in the working tree on all platforms so the
# check-third-party job stays byte-stable regardless of core.autocrlf.
THIRD_PARTY_NOTICES.md text eol=lf

# Vendored license text is consumed verbatim and must not be touched by the
# autocrlf filter, otherwise hash-based integrity checks will drift.
web/src/vendor/THIRD_PARTY_LICENSES.txt text eol=lf

# Shell scripts must keep LF endings to remain executable on Linux runners.
*.sh text eol=lf

# Windows-only PowerShell scripts; let CRLF be the working-tree default.
*.ps1 text eol=crlf
